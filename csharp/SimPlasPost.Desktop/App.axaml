<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SimPlasPost.Desktop.App"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <FluentTheme />

        <!-- Classic-Windows palette: gray 3D face, black text, navy
             accents.  Square corners across all common controls.  The
             FluentTheme handles the actual control templates; we only
             override the surface properties that read cleanly through
             the template (Background, BorderBrush, CornerRadius, Padding).
             All GUI text is bold, sized ~25% above the previous defaults. -->
        <Style Selector="Window">
            <Setter Property="Background" Value="#C0C0C0"/>
            <Setter Property="FontFamily" Value="Tahoma, MS Sans Serif, Segoe UI, sans-serif"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#C0C0C0"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="3,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="RadioButton">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Sidebar section header: navy bold. -->
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="#000080"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="TextBlock.hint">
            <Setter Property="Foreground" Value="#404040"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- View-preset buttons.  Larger surface, axis colour-coded so the
             reader's eye matches them to the screen triad's red/green/blue
             X₁ / X₂ / X₃ arrows without having to read the label. -->
        <Style Selector="Button.ortho">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        <Style Selector="Button.ortho-x"><Setter Property="Foreground" Value="#B0202C"/></Style>
        <Style Selector="Button.ortho-y"><Setter Property="Foreground" Value="#1F8A1F"/></Style>
        <Style Selector="Button.ortho-z"><Setter Property="Foreground" Value="#1A52C8"/></Style>

        <!-- 90° rotation buttons.  Single-glyph labels at a larger point
             size so the rotation arrow reads clearly at a glance. -->
        <Style Selector="Button.rot90">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>
    </Application.Styles>
</Application>
