<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:SimPlasPost.Desktop.Controls"
        x:Class="SimPlasPost.Desktop.Views.MainWindow"
        Title="SIMPLAS Viewer" Width="1100" Height="700">
  <DockPanel>
    <!-- Top bar: examples dropdown -->
    <Border DockPanel.Dock="Top" Background="#C0C0C0" BorderBrush="#808080" BorderThickness="0,0,0,1" Padding="8,5">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="SIMPLAS Viewer" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
        <TextBlock Text="Examples:" VerticalAlignment="Center"/>
        <ComboBox x:Name="CbDemo" MinWidth="260" SelectionChanged="OnDemoSelectionChanged"/>
      </StackPanel>
    </Border>

    <!-- Sidebar -->
    <ScrollViewer DockPanel.Dock="Left" Width="215" Background="#C0C0C0">
      <StackPanel Margin="10,8" Spacing="4">

        <!-- Load Data -->
        <TextBlock Text="Load Data" Classes="section" Margin="0,0,0,4"/>
        <Button x:Name="BtnLoadEnsight" Content="Ensight (.case + files)" Click="OnLoadEnsight" HorizontalAlignment="Stretch"/>
        <Button x:Name="BtnLoadJson" Content="JSON mesh" Click="OnLoadJson" HorizontalAlignment="Stretch"/>
        <TextBlock x:Name="TxtLog" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>

        <!-- Display Mode -->
        <TextBlock Text="Display" Classes="section" Margin="0,10,0,4"/>
        <RadioButton x:Name="RbWireframe" Content="Wireframe" GroupName="DMode" Click="OnDisplayModeChanged"/>
        <RadioButton x:Name="RbPlot" Content="Contour Plot" GroupName="DMode" IsChecked="True" Click="OnDisplayModeChanged"/>
        <RadioButton x:Name="RbLines" Content="Contour Lines" GroupName="DMode" Click="OnDisplayModeChanged"/>

        <StackPanel x:Name="PnlContourN" IsVisible="False" Margin="0,4,0,0">
          <TextBlock x:Name="TxtContourN" Classes="hint"/>
          <Slider x:Name="SlContourN" Minimum="3" Maximum="30" Value="10" IsSnapToTickEnabled="True" TickFrequency="1"
                  ValueChanged="OnContourNChanged"/>
        </StackPanel>

        <!-- Time Step -->
        <StackPanel x:Name="PnlSteps" IsVisible="False" Margin="0,10,0,0">
          <TextBlock Text="Time Step" Classes="section" Margin="0,0,0,4"/>
          <TextBlock x:Name="TxtStep" Classes="hint"/>
          <Slider x:Name="SlStep" Minimum="0" Maximum="1" Value="0" IsSnapToTickEnabled="True" TickFrequency="1"
                  ValueChanged="OnStepChanged"/>
        </StackPanel>

        <!-- Field -->
        <TextBlock Text="Field" Classes="section" Margin="0,10,0,4"/>
        <ComboBox x:Name="CbField" HorizontalAlignment="Stretch" SelectionChanged="OnFieldChanged"/>
        <StackPanel x:Name="PnlFieldRange" IsVisible="False" Margin="0,4,0,0" Spacing="3">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="Min" Classes="hint" Width="28" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtMin" HorizontalAlignment="Stretch" PlaceholderText="auto"
                     LostFocus="OnRangeChanged" KeyDown="OnRangeKeyDown"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="Max" Classes="hint" Width="28" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtMax" HorizontalAlignment="Stretch" PlaceholderText="auto"
                     LostFocus="OnRangeChanged" KeyDown="OnRangeKeyDown"/>
          </StackPanel>
          <Button Content="Reset to auto" Click="OnResetRange"/>
        </StackPanel>

        <!-- Deformation -->
        <TextBlock Text="Deformation" Classes="section" Margin="0,10,0,4"/>
        <CheckBox x:Name="CbShowDef" Content="Deformed shape" Click="OnShowDefChanged"/>
        <TextBlock x:Name="TxtDefScale" Classes="hint" Margin="0,2,0,0"/>
        <Slider x:Name="SlDefScale" Minimum="0" Maximum="20" Value="1" ValueChanged="OnDefScaleChanged"/>

        <!-- View Presets -->
        <TextBlock Text="View" Classes="section" Margin="0,10,0,4"/>
        <Button Content="Zoom to Fit" Click="OnZoomToFit" HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
        <TextBlock Text="Orthographic axes" Classes="hint" Margin="0,0,0,2"/>
        <UniformGrid Columns="3" Margin="0,0,0,4">
          <Button Content="+X" Click="OnPresetView" Tag="pX"/>
          <Button Content="-X" Click="OnPresetView" Tag="nX"/>
          <Button Content="+Y" Click="OnPresetView" Tag="pY"/>
          <Button Content="-Y" Click="OnPresetView" Tag="nY"/>
          <Button Content="+Z" Click="OnPresetView" Tag="pZ"/>
          <Button Content="-Z" Click="OnPresetView" Tag="nZ"/>
        </UniformGrid>
        <TextBlock Text="Isometric" Classes="hint" Margin="0,0,0,2"/>
        <UniformGrid Columns="4" Margin="0,0,0,4">
          <Button Content="FR" Click="OnPresetView" Tag="iFR"/>
          <Button Content="FL" Click="OnPresetView" Tag="iFL"/>
          <Button Content="BR" Click="OnPresetView" Tag="iBR"/>
          <Button Content="BL" Click="OnPresetView" Tag="iBL"/>
        </UniformGrid>

        <!-- Saved Views -->
        <TextBlock Text="Saved Views" Classes="section" Margin="0,10,0,4"/>
        <StackPanel Orientation="Horizontal" Spacing="3" Margin="0,0,0,3">
          <TextBox x:Name="TxtViewName" PlaceholderText="Name (optional)" HorizontalAlignment="Stretch"
                   KeyDown="OnViewNameKeyDown"/>
          <Button Content="Save" Click="OnSaveView"/>
        </StackPanel>
        <ItemsControl x:Name="IcSavedViews">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="3" Margin="0,1">
                <Button Content="{Binding Name}" Click="OnRestoreView" HorizontalAlignment="Stretch"/>
                <Button Content="x" Click="OnDeleteView"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Export -->
        <TextBlock Text="Export" Classes="section" Margin="0,14,0,4"/>
        <TextBlock Text="Vector PDF, white bg, flat shading." Classes="hint" TextWrapping="Wrap" Margin="0,0,0,4"/>
        <Button Content="Export PDF" Click="OnExportPdf" HorizontalAlignment="Stretch"/>
      </StackPanel>
    </ScrollViewer>

    <!-- Main viewport -->
    <controls:MeshViewport x:Name="Viewport" Focusable="True"/>
  </DockPanel>
</Window>
